{
  "entities": {
    "Policy": {
      "title": "Insurance Policy",
      "description": "Details of an LIC insurance policy.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the policy." },
        "category": { "type": "string", "description": "The category of the policy (e.g., Life Insurance, Term Plans)." },
        "description": { "type": "string", "description": "A short description of the policy." },
        "benefits": { "type": "string", "description": "Key benefits of the policy." },
        "eligibility": { "type": "string", "description": "Eligibility criteria for the policy." },
        "riskFactors": { "type": "string", "description": "Risk factors associated with the policy." },
        "keyFeatures": { "type": "string", "description": "Key features of the policy." }
      },
      "required": ["name", "category", "description"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "Detailed profile information for a user.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique identifier for the user." },
        "email": { "type": "string", "description": "The email of the user.", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "The role of the user." },
        "name": { "type": "string", "description": "Full name of the user." },
        "idProof": { "type": "string", "description": "ID proof details (e.g., Aadhar, PAN)." },
        "address": { "type": "string", "description": "Residential address." },
        "gender": { "type": "string", "enum": ["Male", "Female", "Other"], "description": "Gender of the user." },
        "height": { "type": "number", "description": "Height in cm." },
        "weight": { "type": "number", "description": "Weight in kg." },
        "age": { "type": "integer", "description": "Age of the user." },
        "dob": { "type": "string", "format": "date", "description": "Date of birth." },
        "qualification": { "type": "string", "description": "Educational qualification." },
        "maritalStatus": { "type": "string", "enum": ["Single", "Married", "Divorced", "Widowed"], "description": "Marital status." },
        "occupationalDetails": { "type": "string", "description": "Details about the user's occupation." },
        "annualIncome": { "type": "number", "description": "Annual income in INR." },
        "medicalHistory": { "type": "string", "description": "Any relevant medical history." }
      },
      "required": ["uid", "email", "role", "name"]
    },
    "Contact": {
      "title": "Contact Submission",
      "description": "A contact form submission from a user.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the user." },
        "email": { "type": "string", "description": "The email of the user.", "format": "email" },
        "message": { "type": "string", "description": "The message from the user." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the message was sent." }
      },
      "required": ["name", "email", "message"]
    }
  },
  "firestore": {
    "/policies/{policyId}": {
      "schema": "Policy",
      "description": "A collection of LIC insurance policies."
    },
    "/contacts/{contactId}": {
      "schema": "Contact",
      "description": "A collection of contact form submissions."
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "A collection of user profiles."
    }
  }
}
